# Conexión a PostgreSQL (boc_dataset + boc_log)
# Construida a partir de las variables individuales en docker-compose.yml
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/boc

# Variables individuales (usadas por docker-compose para construir DATABASE_URL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=boc
POSTGRES_USER=root
POSTGRES_PASSWORD=root

# Next.js
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# URL base del sitio (usada en sitemap y robots.txt)
SITE_URL=https://bocana.org
