// Prisma schema — Bocana
// Mapea las tablas del pipeline (boc_dataset) y las vistas de métricas (boc_log)
// como cliente de solo lectura. Este proyecto no gestiona migraciones.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["boc_dataset", "boc_log"]
}

// ── boc_dataset.issue ─────────────────────────────────────────────────────

model Issue {
  dltId            String             @id @map("_dlt_id") @db.VarChar
  dltLoadId        String             @map("_dlt_load_id") @db.VarChar
  year             BigInt
  issue            BigInt
  title            String?            @db.VarChar
  url              String?            @db.VarChar
  summaryUrl       String?            @map("summary__url") @db.VarChar
  summarySignature String?            @map("summary__signature") @db.VarChar
  dispositions     IssueDisposition[]

  @@map("issue")
  @@schema("boc_dataset")
}

// ── boc_dataset.issue__dispositions ──────────────────────────────────────
// Listado de disposiciones tal como aparecen en el índice del boletín.
// Contiene metadatos de índice y resumen; el texto completo está en Document.
// La columna summary_tsv es un tsvector generado (no se declara aquí;
// se usa directamente en raw queries con @@ y ts_headline).

model IssueDisposition {
  dltId        String  @id @map("_dlt_id") @db.VarChar
  dltRootId    String  @map("_dlt_root_id") @db.VarChar
  dltParentId  String  @map("_dlt_parent_id") @db.VarChar
  dltListIdx   BigInt  @map("_dlt_list_idx")
  disposition  BigInt?
  section      String? @db.VarChar
  subsection   String? @db.VarChar
  organization String? @db.VarChar
  summary      String? @db.VarChar
  metadata     String? @db.VarChar
  identifier   String? @db.VarChar
  pdf          String? @db.VarChar
  html         String? @db.VarChar
  signature    String? @db.VarChar
  issue        Issue   @relation(fields: [dltRootId], references: [dltId])

  @@map("issue__dispositions")
  @@schema("boc_dataset")
}

// ── boc_dataset.document ─────────────────────────────────────────────────
// Texto completo de cada disposición extraído del HTML oficial.
// La columna body_tsv es un tsvector generado (no se declara aquí;
// se usa directamente en raw queries con @@ y ts_headline).

model Document {
  dltId        String  @id @map("_dlt_id") @db.VarChar
  dltLoadId    String  @map("_dlt_load_id") @db.VarChar
  year         BigInt
  issue        BigInt
  number       String  @db.VarChar
  document     String? @db.VarChar
  date         String? @db.VarChar
  entity       String? @db.VarChar
  section      String? @db.VarChar
  subsection   String? @db.VarChar
  organization String? @db.VarChar
  identifier   String? @db.VarChar
  pdf          String? @db.VarChar
  signature    String? @db.VarChar
  title        String? @db.VarChar
  body         String? @db.VarChar

  @@map("document")
  @@schema("boc_dataset")
}

// ── boc_log — vistas de métricas ─────────────────────────────────────────
// Las vistas no tienen clave primaria; se consultan con $queryRaw
// en MetricsRepository. No se definen modelos Prisma para ellas.
