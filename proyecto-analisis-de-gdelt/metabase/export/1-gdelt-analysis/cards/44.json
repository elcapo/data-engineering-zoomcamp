  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "WITH events_last_24h AS (\n    SELECT\n        actor1_country AS country,\n        to_timestamp(date_added::text, 'YYYYMMDDHH24MISS') AS event_ts\n    FROM public.events\n    WHERE date_added >= to_char(now() - interval '24 hours', 'YYYYMMDDHH24MISS')::bigint\n      AND actor1_country IS NOT NULL\n      AND actor1_country <> ''\n),\ntop_10_countries AS (\n    SELECT country\n    FROM events_last_24h\n    GROUP BY country\n    ORDER BY COUNT(*) DESC\n    LIMIT 10\n)\nSELECT\n\tucc.name AS country_name,\n    COUNT(*) AS event_count\nFROM events_last_24h AS e\nJOIN top_10_countries AS t USING (country)\nINNER JOIN public_lookup.un_country_code AS ucc ON ucc.iso3 = e.country\nGROUP BY e.country, ucc.name\nORDER BY event_count DESC;\n"
      }
    ]
  },
