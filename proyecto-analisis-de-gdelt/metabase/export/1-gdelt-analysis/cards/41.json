  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "WITH top_event_codes AS (\n  SELECT\n    event_root_code,\n    event_root_description,\n    SUM(event_count) AS event_count\n  FROM public_dashboard.event_volume\n  WHERE\n    window_start >= NOW() - INTERVAL '1 day'\n  GROUP BY\n    event_root_code,\n    event_root_description\n  ORDER BY\n    event_count DESC\n  LIMIT 10\n)\nSELECT\n  DATE_TRUNC('hour', public_dashboard.event_volume.window_start) AS event_hour,\n  public_dashboard.event_volume.event_root_description AS event_root_description,\n  SUM(public_dashboard.event_volume.event_count) AS sum\nFROM public_dashboard.event_volume\nLEFT JOIN (\n  SELECT\n    public_lookup.event_root_code.event_root_code AS event_root_code,\n    public_lookup.event_root_code.description AS description\n  FROM\n    public_lookup.event_root_code\n) AS \"Event Root Code\" ON public_dashboard.event_volume.event_root_code = \"Event Root Code\".event_root_code\nWHERE\n  public_dashboard.event_volume.event_root_code IN (\n    SELECT event_root_code FROM top_event_codes\n  )\nGROUP BY\n  DATE_TRUNC('hour', public_dashboard.event_volume.window_start),\n  public_dashboard.event_volume.event_root_description\nORDER BY\n  DATE_TRUNC('hour', public_dashboard.event_volume.window_start) ASC,\n  public_dashboard.event_volume.event_root_description ASC"
      }
    ]
  },
