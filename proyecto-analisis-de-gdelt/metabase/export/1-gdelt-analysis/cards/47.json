  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "native": "WITH gkg_last_24h AS (\n    SELECT organizations, tone\n    FROM public.gkg\n    WHERE gkg_date >= to_char(now() - interval '24 hours', 'YYYYMMDDHH24MISS')::bigint\n      AND organizations IS NOT NULL\n      AND organizations <> ''\n      AND tone IS NOT NULL\n),\nexploded_organizations AS (\n    SELECT\n        trim(organization) AS organization,\n        tone\n    FROM gkg_last_24h,\n         unnest(string_to_array(organizations, ';')) AS organization\n    WHERE trim(organization) <> ''\n)\nSELECT\n    initcap(organization) AS organization,\n    COUNT(*) AS article_count,\n    ROUND(AVG(tone)::numeric, 3) AS avg_tone\nFROM exploded_organizations\nGROUP BY organization\nHAVING COUNT(*) >= 10\nORDER BY article_count DESC\nLIMIT 25;",
        "lib/type": "mbql.stage/native"
      }
    ]
  },
