  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "WITH gkg_last_24h AS (\n    SELECT persons, tone\n    FROM public.gkg\n    WHERE gkg_date >= to_char(now() - interval '24 hours', 'YYYYMMDDHH24MISS')::bigint\n      AND persons IS NOT NULL\n      AND persons <> ''\n      AND tone IS NOT NULL\n),\nexploded_persons AS (\n    SELECT\n        trim(person) AS person,\n        tone\n    FROM gkg_last_24h,\n         unnest(string_to_array(persons, ';')) AS person\n    WHERE trim(person) <> ''\n)\nSELECT\n    initcap(person) AS person,\n    COUNT(*) AS article_count,\n    ROUND(AVG(tone)::numeric, 3) AS avg_tone\nFROM exploded_persons\nGROUP BY person\nHAVING COUNT(*) >= 10\nORDER BY article_count DESC\nLIMIT 25;\n"
      }
    ]
  },
