  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "native": "WITH top_countries AS (\n  SELECT country\n  FROM \"public\".\"event_counts_by_country\"\n  WHERE window_start >= NOW() - (INTERVAL '1 hour' * 10)\n    AND country IS NOT NULL\n    AND country <> ''\n  GROUP BY country\n  ORDER BY SUM(event_count) DESC\n  LIMIT 10\n)\nSELECT\n  CONCAT(DATE_PART('hour', ct.window_start), ':00') AS event_hour,\n  cc.name AS country_name,\n  ROUND(CAST(AVG(ct.avg_goldstein) AS NUMERIC), 2) AS avg_goldstein\nFROM \"public_dashboard\".\"conflict_trend\" AS ct\nINNER JOIN \"public_lookup\".\"un_country_code\" AS cc ON cc.iso3 = ct.country\nINNER JOIN top_countries tc USING (country)\nWHERE ct.window_start >= NOW() - (INTERVAL '1 hour' * 10)\nGROUP BY 1, 2\nORDER BY 1 ASC, 2 ASC",
        "lib/type": "mbql.stage/native"
      }
    ]
  },
