  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "WITH mentions_last_24h AS (\n    SELECT\n        m.global_event_id,\n        to_timestamp(m.mention_time_date::text, 'YYYYMMDDHH24MISS') AS mention_ts\n    FROM public.mentions AS m\n    JOIN public.events AS e USING (global_event_id)\n    WHERE m.mention_time_date >= to_char(now() - interval '24 hours', 'YYYYMMDDHH24MISS')::bigint\n),\ntop_10_events AS (\n    SELECT global_event_id\n    FROM mentions_last_24h\n    GROUP BY global_event_id\n    ORDER BY COUNT(*) DESC\n    LIMIT 10\n)\nSELECT\n    m.global_event_id,\n    e.action_geo_name,\n    erc.description AS event_description,\n    COUNT(*) AS mention_count\nFROM mentions_last_24h AS m\nJOIN top_10_events AS t USING (global_event_id)\nINNER JOIN public.events AS e ON e.global_event_id = m.global_event_id\nINNER JOIN public_lookup.event_root_code AS erc ON erc.event_root_code = e.event_root_code\nGROUP BY\n    m.global_event_id,\n    e.action_geo_name,\n    erc.description\nORDER BY\n    m.global_event_id"
      }
    ]
  },
