# Copy this file to .env and adjust values as needed.
# All variables have sensible defaults, so a custom .env file is only
# required if you need to override something (e.g. port conflicts).

# --- PostgreSQL ---
# POSTGRES_USER=gdelt
# POSTGRES_PASSWORD=gdelt
# POSTGRES_DB=gdelt
# POSTGRES_PORT=5432

# --- Redpanda ---
# REDPANDA_PORT=9092
# REDPANDA_CONSOLE_PORT=8080

# --- Kestra ---
# KESTRA_PORT=8082

# --- Flink ---
# FLINK_PORT=8081
# FLINK_TASK_SLOTS=4

# --- Grafana ---
# GRAFANA_PORT=3000
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin
