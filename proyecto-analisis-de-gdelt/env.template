# Run `make init` to generate a .env from this template. The three
# __*_PASSWORD__ placeholders below are replaced with random passwords
# at generation time. Everything else has sensible defaults and is
# commented out — uncomment only what you need to override.

# Directorio que contiene el socket de Docker (docker.sock)
# Esta línea se puede dejar comentada si el socket está en /var/run/docker.sock
# DOCKER_SOCKET_DIR=${XDG_RUNTIME_DIR}

# --- Kestra ---
# KESTRA_PORT=8080
# KESTRA_USER="admin@kestra.io" # it must be a valid email address
KESTRA_PASSWORD="__KESTRA_PASSWORD__"  # it must be at least 8 characters long with uppercase letter and a number

# --- Redpanda ---
# REDPANDA_PORT=9092
# REDPANDA_CONSOLE_PORT=8081

# --- Flink ---
# FLINK_PORT=8082
# FLINK_TASK_SLOTS=4

# --- PostgreSQL ---
# POSTGRES_PORT=5432
# POSTGRES_USER=gdelt
# POSTGRES_DB=gdelt
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__

# --- pgAdmin ---
# PGADMIN_PORT=8083
# PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=__PGADMIN_PASSWORD__

# --- Metabase ---
# METABASE_PORT=8084
# METABASE_USER=admin@admin.com
METABASE_PASSWORD=__METABASE_PASSWORD__
