{
  "uid": "gdelt-realtime",
  "title": "GDELT Real-Time Analysis",
  "tags": ["gdelt", "streaming"],
  "timezone": "browser",
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Global Event Map",
      "type": "geomap",
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "gdelt-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "gdelt-postgres" },
          "rawSql": "SELECT action_geo_lat AS latitude, action_geo_long AS longitude, goldstein_scale, action_geo_name, event_root_code FROM events WHERE action_geo_lat IS NOT NULL AND action_geo_long IS NOT NULL AND date_added > EXTRACT(EPOCH FROM NOW() - INTERVAL '24 hours') * 1000000 ORDER BY date_added DESC LIMIT 500;",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "options": {
        "view": {
          "id": "zero",
          "lat": 20,
          "lon": 0,
          "zoom": 2
        },
        "basemap": {
          "type": "default"
        },
        "layers": [
          {
            "type": "markers",
            "name": "Events",
            "config": {
              "showLegend": true,
              "style": {
                "color": {
                  "field": "goldstein_scale",
                  "fixed": "dark-green"
                },
                "opacity": 0.6,
                "size": {
                  "fixed": 5,
                  "min": 3,
                  "max": 10
                }
              }
            },
            "location": {
              "mode": "coords",
              "latitude": "latitude",
              "longitude": "longitude"
            }
          }
        ]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Event Volume by Type",
      "type": "timeseries",
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "gdelt-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "gdelt-postgres" },
          "rawSql": "SELECT window_start AS time, event_root_code, SUM(event_count) AS event_count FROM event_counts_by_country WHERE $__timeFilter(window_start) GROUP BY window_start, event_root_code ORDER BY window_start;",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum"]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": { "mode": "normal" },
            "fillOpacity": 80
          },
          "unit": "short"
        },
        "overrides": []
      },
      "transformations": [
        {
          "id": "prepareTimeSeries",
          "options": {
            "format": "multi"
          }
        }
      ]
    },
    {
      "id": 3,
      "title": "Conflict Trend (Goldstein Scale)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "gdelt-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "gdelt-postgres" },
          "rawSql": "SELECT window_start AS time, country, avg_goldstein FROM conflict_trend WHERE $__timeFilter(window_start) AND country IN (SELECT country FROM conflict_trend WHERE $__timeFilter(window_start) GROUP BY country ORDER BY COUNT(*) DESC LIMIT 5) ORDER BY window_start;",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "short",
          "decimals": 2
        },
        "overrides": []
      },
      "transformations": [
        {
          "id": "prepareTimeSeries",
          "options": {
            "format": "multi"
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "Top 20 Actors",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "postgres", "uid": "gdelt-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "gdelt-postgres" },
          "rawSql": "SELECT actor_code, event_count FROM top_actors WHERE window_start = (SELECT MAX(window_start) FROM top_actors) AND actor_code IS NOT NULL AND actor_code <> '' ORDER BY event_count DESC LIMIT 20;",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "legend": {
          "displayMode": "hidden"
        },
        "xTickLabelRotation": 0,
        "showValue": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Media Attention",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "postgres", "uid": "gdelt-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "gdelt-postgres" },
          "rawSql": "SELECT window_start AS time, SUM(mention_count) AS total_mentions FROM media_attention WHERE $__timeFilter(window_start) GROUP BY window_start ORDER BY window_start;",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "pointSize": 5,
            "showPoints": "auto"
          },
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Tone Analysis by Theme",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "postgres", "uid": "gdelt-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "gdelt-postgres" },
          "rawSql": "SELECT theme, avg_tone FROM tone_by_theme WHERE window_start = (SELECT MAX(window_start) FROM tone_by_theme) AND theme IS NOT NULL AND theme <> '' ORDER BY ABS(avg_tone) DESC LIMIT 20;",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "legend": {
          "displayMode": "hidden"
        },
        "xTickLabelRotation": 0,
        "showValue": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "unit": "short",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": -2 },
              { "color": "green", "value": 2 }
            ]
          }
        },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true
}
