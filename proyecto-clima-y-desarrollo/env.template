# Run `make init` to generate a .env from this template. The __*_PASSWORD__
# placeholders below are replaced with random passwords at generation time.
# Everything else has sensible defaults and is commented out — uncomment only
# what you need to override.

# Directory containing the Docker socket (docker.sock).
# Leave commented if the socket lives at /var/run/docker.sock.
# DOCKER_SOCKET_DIR=${XDG_RUNTIME_DIR}

# --- Kestra ---
# KESTRA_PORT=8080
# KESTRA_USER="admin@kestra.io" # must be a valid email address
KESTRA_PASSWORD="__KESTRA_PASSWORD__"  # ≥8 chars, uppercase + number

# --- PostgreSQL ---
# POSTGRES_PORT=5432
# POSTGRES_USER=climate
# POSTGRES_DB=climate
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__

# --- MinIO (S3-compatible object storage) ---
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001
# MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=__MINIO_ROOT_PASSWORD__

# --- Storage (S3 API; values match MinIO defaults locally) ---
# STORAGE_ENDPOINT=http://minio:9000
# STORAGE_BUCKET=climate
# STORAGE_REGION=us-east-1
# Locally these default to MINIO_ROOT_USER / MINIO_ROOT_PASSWORD; set them
# explicitly for cloud (e.g. GCS HMAC access/secret pair).
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=

# --- World Bank ingestion ---
# WORLDBANK_API_BASE_URL=https://api.worldbank.org/v2
# Comma-separated list of World Bank indicator codes to ingest.
# INDICATORS=NY.GDP.PCAP.CD,NY.GDP.MKTP.KD.ZG,EN.ATM.CO2E.PC,EG.USE.PCAP.KG.OE,EG.FEC.RNEW.ZS,SP.URB.TOTL.IN.ZS,NV.IND.TOTL.ZS,EN.POP.DNST

# --- Redpanda (Kafka-compatible broker) ---
# REDPANDA_PORT=9092
# REDPANDA_CONSOLE_PORT=8081
# KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# --- Flink ---
# FLINK_PORT=8082
# FLINK_TASK_SLOTS=2

# --- Spark backfill (OpenAQ historical from public S3 dump) ---
# SPARK_MASTER=local[*]
# Default smoke-test scope: a single station in Albuquerque, NM, US for 2023.
# Override all three together if you want to target a different country.
# SPARK_BACKFILL_LOCATIONS=2178
# SPARK_BACKFILL_YEARS=2023
# SPARK_BACKFILL_COUNTRY_ISO=US

# --- OpenAQ ingestion ---
# OPENAQ_API_BASE_URL=https://api.openaq.org
# Get a free API key at https://explore.openaq.org/register
OPENAQ_API_KEY=
# COUNTRIES=ES          # ISO2 codes, comma-separated; required for openaq-poll to do anything
# PARAMETERS=pm25,pm10,no2,o3,so2
# OPENAQ_TOPIC=openaq.measurements

# --- Warehouse selection (postgres = local, bigquery = cloud) ---
# WAREHOUSE_BACKEND=postgres

# --- BigQuery (only for cloud mode) ---
# BIGQUERY_PROJECT=
# BIGQUERY_DATASET=climate
# BIGQUERY_LOCATION=EU
# BIGQUERY_KEYFILE=/secrets/gcp-key.json
