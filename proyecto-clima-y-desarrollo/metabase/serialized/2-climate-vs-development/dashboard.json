                  "id": "year-tag",
                  "name": "year",
                  "display-name": "Year",
                  "required": false
                }
              },
              "lib/type": "mbql.stage/native",
              "native": "WITH ranked AS (\n  SELECT country_iso3, country_name, year,\n         co2_per_capita_t, median_pm25_ugm3,\n         ROW_NUMBER() OVER (\n           PARTITION BY country_iso3 ORDER BY year DESC\n         ) AS rn\n  FROM marts.country_year_environment\n  WHERE co2_per_capita_t IS NOT NULL\n    AND median_pm25_ugm3 IS NOT NULL\n    AND median_pm25_ugm3 > 0\n    [[ AND year = {{year}} ]]\n)\nSELECT c.iso2                                      AS country_iso2,\n       r.country_iso3,\n       r.country_name,\n       r.year                                      AS latest_year,\n       r.co2_per_capita_t,\n       r.median_pm25_ugm3,\n       r.co2_per_capita_t / r.median_pm25_ugm3     AS ratio_co2_pm25\nFROM ranked r\nJOIN seeds.country_iso_codes c\n  ON c.iso3 = r.country_iso3\nWHERE r.rn = 1\nORDER BY country_iso2"
            }
          ]
        },
