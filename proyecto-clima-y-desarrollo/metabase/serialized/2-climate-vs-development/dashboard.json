        "name": "04 — Decoupling: GDP vs PM2.5 indexed (base 100)",
        "document_id": null,
        "last_used_at": "2026-05-03T19:18:22.792659Z",
        "type": "question",
        "dimensions": null,
        "query_average_duration": null,
        "creator_id": 1,
        "moderation_reviews": [],
        "updated_at": "2026-05-03T19:17:58.412408Z",
        "made_public_by_id": null,
        "embedding_params": null,
        "cache_ttl": null,
        "dataset_query": {
          "lib/type": "mbql/query",
          "database": 2,
          "stages": [
            {
              "lib/type": "mbql.stage/native",
              "template-tags": {
                "country_iso2": {
                  "type": "text",
                  "default": "US",
                  "id": "country-iso2-tag",
                  "name": "country_iso2",
                  "display-name": "Country (ISO2)",
                  "required": true
                }
              },
              "native": "WITH base AS (\n  SELECT m.country_iso3, m.year,\n         m.gdp_per_capita_usd, m.median_pm25_ugm3,\n         FIRST_VALUE(m.gdp_per_capita_usd) OVER (\n           PARTITION BY m.country_iso3 ORDER BY m.year\n         ) AS gdp_base,\n         FIRST_VALUE(m.median_pm25_ugm3) OVER (\n           PARTITION BY m.country_iso3 ORDER BY m.year\n         ) AS pm25_base\n  FROM marts.country_year_environment m\n  JOIN seeds.country_iso_codes c\n    ON c.iso3 = m.country_iso3\n  WHERE c.iso2 = {{country_iso2}}\n    AND m.gdp_per_capita_usd IS NOT NULL\n    AND m.median_pm25_ugm3 IS NOT NULL\n)\nSELECT year,\n       100.0 * gdp_per_capita_usd / gdp_base  AS gdp_index,\n       100.0 * median_pm25_ugm3   / pm25_base AS pm25_index\nFROM base\nORDER BY year"
            }
          ]
        },
