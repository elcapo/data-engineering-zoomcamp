                  "display-name": "Year",
                  "id": "year-tag",
                  "name": "year",
                  "type": "number"
                }
              },
              "lib/type": "mbql.stage/native",
              "native": "SELECT country_iso3,\n       co2_per_capita_t / NULLIF(median_pm25_ugm3, 0) AS ratio_co2_pm25,\n       co2_per_capita_t,\n       median_pm25_ugm3,\n       year\nFROM marts.country_year_environment\nWHERE [[ year = {{year}} AND ]]\n      co2_per_capita_t IS NOT NULL\n  AND median_pm25_ugm3 IS NOT NULL"
            }
          ]
