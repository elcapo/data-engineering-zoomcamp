  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "template-tags": {
          "country_iso3": {
            "default": "USA",
            "id": "country-iso3-tag",
            "name": "country_iso3",
            "display-name": "Country (ISO3)",
            "type": "text",
            "required": true
          }
        },
        "lib/type": "mbql.stage/native",
        "native": "WITH base AS (\n  SELECT country_iso3, year,\n         gdp_per_capita_usd, median_pm25_ugm3,\n         FIRST_VALUE(gdp_per_capita_usd) OVER (\n           PARTITION BY country_iso3 ORDER BY year\n         ) AS gdp_base,\n         FIRST_VALUE(median_pm25_ugm3) OVER (\n           PARTITION BY country_iso3 ORDER BY year\n         ) AS pm25_base\n  FROM marts.country_year_environment\n  WHERE country_iso3 = {{country_iso3}}\n    AND gdp_per_capita_usd IS NOT NULL\n    AND median_pm25_ugm3 IS NOT NULL\n)\nSELECT year,\n       100.0 * gdp_per_capita_usd / gdp_base  AS gdp_index,\n       100.0 * median_pm25_ugm3   / pm25_base AS pm25_index\nFROM base\nORDER BY year"
      }
    ]
  },
