  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "template-tags": {
          "country_iso2": {
            "type": "text",
            "id": "country-iso2-tag",
            "name": "country_iso2",
            "display-name": "Countries (ISO2)",
            "required": false
          }
        },
        "lib/type": "mbql.stage/native",
        "native": "WITH base AS (\n  SELECT m.country_iso3, c.iso2 AS country_iso2, m.year,\n         m.gdp_per_capita_usd, m.pm25_annual_satellite_ugm3,\n         FIRST_VALUE(m.gdp_per_capita_usd) OVER (\n           PARTITION BY m.country_iso3 ORDER BY m.year\n         ) AS gdp_base,\n         FIRST_VALUE(m.pm25_annual_satellite_ugm3) OVER (\n           PARTITION BY m.country_iso3 ORDER BY m.year\n         ) AS pm25_base\n  FROM marts.country_year_environment m\n  JOIN seeds.country_iso_codes c\n    ON c.iso3 = m.country_iso3\n  WHERE c.iso2 IN ('US','DE','CN','MX','IN','ZA')\n    [[ AND c.iso2 IN ({{country_iso2}}) ]]\n    AND m.gdp_per_capita_usd IS NOT NULL\n    AND m.pm25_annual_satellite_ugm3 IS NOT NULL\n)\nSELECT year, country_iso2,\n       100.0 * pm25_annual_satellite_ugm3 / pm25_base AS pm25_index\nFROM base\nORDER BY year, country_iso2"
      }
    ]
  },
