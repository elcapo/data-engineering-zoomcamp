        "native": "SELECT m.year,\n       m.gdp_growth_pct,\n       m.pm25_annual_satellite_ugm3\nFROM marts.country_year_environment m\nJOIN seeds.country_iso_codes c\n  ON c.iso3 = m.country_iso3\nWHERE c.iso2 = {{country_iso2}}\nORDER BY m.year"
      }
    ]
