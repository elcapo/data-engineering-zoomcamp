  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "template-tags": {
          "country_iso2": {
            "type": "text",
            "id": "country-iso2-tag",
            "name": "country_iso2",
            "display-name": "Countries (ISO2)",
            "required": false
          }
        },
        "lib/type": "mbql.stage/native",
        "native": "SELECT m.year,\n       c.iso2 AS country_iso2,\n       m.pm25_annual_satellite_ugm3\nFROM marts.country_year_environment m\nJOIN seeds.country_iso_codes c\n  ON c.iso3 = m.country_iso3\nWHERE c.iso2 IN ('US','DE','CN','MX','IN','ZA')\n  [[ AND c.iso2 IN ({{country_iso2}}) ]]\n  AND m.pm25_annual_satellite_ugm3 IS NOT NULL\nORDER BY m.year, country_iso2"
      }
    ]
  },
