  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "template-tags": {
          "year": {
            "display-name": "Year",
            "type": "number",
            "id": "year-tag",
            "name": "year",
            "required": false
          }
        },
        "native": "WITH ranked AS (\n  SELECT m.country_iso3, m.country_name, m.year,\n         m.co2_per_capita_t, m.pm25_annual_satellite_ugm3,\n         ROW_NUMBER() OVER (\n           PARTITION BY m.country_iso3 ORDER BY m.year DESC\n         ) AS rn\n  FROM marts.country_year_environment m\n  WHERE m.co2_per_capita_t IS NOT NULL\n    AND m.pm25_annual_satellite_ugm3 IS NOT NULL\n    AND m.pm25_annual_satellite_ugm3 > 0\n    [[ AND m.year = {{year}} ]]\n)\nSELECT c.iso2 AS country_iso2,\n       r.country_iso3, r.country_name,\n       r.year AS latest_year,\n       r.co2_per_capita_t, r.pm25_annual_satellite_ugm3,\n       r.co2_per_capita_t / r.pm25_annual_satellite_ugm3 AS ratio_co2_pm25\nFROM ranked r\nJOIN seeds.country_iso_codes c\n  ON c.iso3 = r.country_iso3\nWHERE r.rn = 1\nORDER BY country_iso2"
      }
    ]
  },
