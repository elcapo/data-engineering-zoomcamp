  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "WITH ranked AS (\n  SELECT m.country_iso3, m.country_name, m.year,\n         m.gdp_per_capita_usd, m.pm25_annual_satellite_ugm3, m.population_total,\n         ROW_NUMBER() OVER (\n           PARTITION BY m.country_iso3 ORDER BY m.year DESC\n         ) AS rn\n  FROM marts.country_year_environment m\n  WHERE m.gdp_per_capita_usd IS NOT NULL\n    AND m.pm25_annual_satellite_ugm3 IS NOT NULL\n    AND m.population_total IS NOT NULL\n)\nSELECT c.iso2 AS country_iso2,\n       r.country_name, r.year,\n       r.gdp_per_capita_usd, r.pm25_annual_satellite_ugm3,\n       r.population_total,\n       LN(r.population_total) AS log_population\nFROM ranked r\nJOIN seeds.country_iso_codes c\n  ON c.iso3 = r.country_iso3\nWHERE r.rn = 1\n  AND c.iso2 IN ('US','DE','CN','MX','IN','ZA')\n  [[ AND c.iso2 IN ({{country_iso2}}) ]]\nORDER BY country_iso2",
        "template-tags": {
          "country_iso2": {
            "display-name": "Countries (ISO2)",
            "type": "text",
            "id": "country-iso2-tag",
            "name": "country_iso2",
            "required": false
          }
        }
      }
    ]
  },
