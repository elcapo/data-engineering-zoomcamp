  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "WITH ranked AS (\n  SELECT country_iso3, country_name, year,\n         gdp_per_capita_usd, median_pm25_ugm3,\n         ROW_NUMBER() OVER (\n           PARTITION BY country_iso3 ORDER BY year DESC\n         ) AS rn\n  FROM marts.country_year_environment\n  WHERE gdp_per_capita_usd IS NOT NULL\n    AND median_pm25_ugm3 IS NOT NULL\n)\nSELECT country_iso3, country_name, year,\n       gdp_per_capita_usd, median_pm25_ugm3\nFROM ranked\nWHERE rn = 1"
      }
    ]
  },
